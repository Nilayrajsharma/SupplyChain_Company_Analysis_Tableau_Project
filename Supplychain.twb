      <column caption='Sales Per Customer' datatype='real' name='[Calculation_0358189625630720]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(&#13;&#10;[Sales]) / COUNTD([Customer Id])' />
      </column>
      <column caption='Late delivery %' datatype='real' default-format='p0.00%' name='[Calculation_0947802675453952]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(if [Late_delivery_risk] = 1 THEN 1 ELSE 0 END)&#13;&#10;/ COUNT([Order Id])' />
      </column>
      <column caption='Avg Shipping Delay' datatype='integer' name='[Calculation_0947802684530689]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Days for shipping (real)] - [Days for shipment (scheduled)]' />
      </column>
      <column caption='avg delay day' datatype='real' default-format='p0.00%' name='[Calculation_0947802685501442]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Calculation_0947802684530689])' />
      </column>
      <column caption='Canceled Orders' datatype='real' default-format='p0.00%' name='[Calculation_0947802686713859]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum(if [Delivery Status] = &quot;Shipping canceled&quot; then 1 else 0&#13;&#10;end)&#13;&#10;/COUNT([Order Id])' />
